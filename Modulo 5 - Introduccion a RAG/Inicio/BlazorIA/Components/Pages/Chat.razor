@page "/"
@using BlazorIA.DTOs
@using BlazorIA.Servicios.Chatbots
@using BlazorIA.Utilidades
@implements IDisposable
@inject IChatbot ChatSession
@inject IJSRuntime JS

<div class="chat-wrapper">
    <h3 class="chat-titulo">Chat con IA</h3>

    <div class="chat-mensajes" @ref="contenedorMensajes">
        @foreach (var mensaje in ChatSession.Conversacion)
        {
            <div class="mensaje @ObtenerClaseCSS(mensaje.Rol)">
                <div class="mensaje-header">@ObtenerEtiqueta(mensaje.Rol)</div>
                <div class="mensaje-body">@mensaje.Texto</div>
            </div>
        }

        @if (ChatSession.AprobacionPendiente is not null)
        {
            <div class="aprobacion-tool">
                <h4>La IA desea ejecutar una acción sensible</h4>
                <p><strong>Tool:</strong> @ChatSession.AprobacionPendiente.NombreTool</p>

                @if (ChatSession.AprobacionPendiente.Argumentos.Count > 0)
                {
                    <ul>
                        @foreach (var argumento in ChatSession.AprobacionPendiente.Argumentos)
                        {
                            <li><strong>@argumento.Key:</strong> @argumento.Value</li>
                        }
                    </ul>
                }

                <div class="acciones-aprobacion">
                    <button class="btn btn-success"
                            @onclick="Aprobar"
                            disabled="@ChatSession.EstaProcesando">
                        Aprobar
                    </button>

                    <button class="btn btn-danger"
                            @onclick="Rechazar"
                            disabled="@ChatSession.EstaProcesando">
                        Rechazar
                    </button>
                </div>
            </div>
        }

    </div>

    <EditForm Model="modelo" OnValidSubmit="Enviar">
        <div class="entrada-chat">

            <select class="form-select selector-modelo"
                    @bind="modeloSeleccionado"
                    @bind:after="OnCambioModelo"
                    disabled="@(ChatSession.EstaProcesando || ChatSession.AprobacionPendiente is not null)">
                @foreach (var item in modelosDisponibles)
                {
                    <option value="@item">@item</option>
                }
            </select>


            <input class="form-control"
                   @bind="modelo.Texto"
                   @bind:event="oninput"
                   placeholder="Escribe tu mensaje..." />

            <button type="submit"
                    class="btn btn-primary"
                    disabled="@DeshabilitarEnvio">
                Enviar
            </button>

            <button type="button"
                    class="btn btn-outline-secondary"
                    @onclick="Cancelar"
                    disabled="@(!ChatSession.EstaProcesando)">
                Cancelar
            </button>
        </div>
    </EditForm>
</div>


@code {
    private readonly ChatInputModel modelo = new();
    private ElementReference contenedorMensajes;
    private bool necesitaScroll;

    private readonly List<string> modelosDisponibles = ModelosIA.ObtenerModelosDisponibles().ToList();
    private string modeloSeleccionado = ModelosIA.ObtenerModeloPorDefecto;

    private void OnCambioModelo()
    {
        ChatSession.SetearModelo(modeloSeleccionado);
    }

    private bool DeshabilitarEnvio =>
    ChatSession.EstaProcesando ||
    ChatSession.AprobacionPendiente is not null ||
    string.IsNullOrWhiteSpace(modelo.Texto);

    protected override void OnInitialized()
    {
        ChatSession.OnChange += ManejarCambioChat;
    }

    private void ManejarCambioChat()
    {
        necesitaScroll = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task Aprobar()
    {
        necesitaScroll = true;
        await ChatSession.ResolverAprobacionAsync(true);
    }

    private async Task Rechazar()
    {
        necesitaScroll = true;
        await ChatSession.ResolverAprobacionAsync(false);
    }

    private async Task Enviar()
    {
        var texto = modelo.Texto?.Trim();

        if (string.IsNullOrWhiteSpace(texto))
        {
            return;
        }

        modelo.Texto = string.Empty;
        necesitaScroll = true;

        await ChatSession.EnviarMensajeAsync(texto);
    }

    private Task Cancelar()
    {
        ChatSession.CancelarRespuestaActual();
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (necesitaScroll)
        {
            necesitaScroll = false;
            await JS.InvokeVoidAsync("chatScroll.scrollToBottom", contenedorMensajes);
        }
    }

    private static string ObtenerEtiqueta(RolMensaje rol) => rol switch
    {
        RolMensaje.Usuario => "Tú",
        RolMensaje.IA => "IA",
        RolMensaje.Sistema => "Sistema",
        _ => rol.ToString()
    };

    private static string ObtenerClaseCSS(RolMensaje rol) => rol switch
    {
        RolMensaje.Usuario => "user",
        RolMensaje.IA => "assistant",
        RolMensaje.Sistema => "system",
        _ => rol.ToString()
    };

    public void Dispose()
    {
        ChatSession.OnChange -= ManejarCambioChat;
    }


    private class ChatInputModel
    {
        public string Texto { get; set; } = string.Empty;
    }


}
